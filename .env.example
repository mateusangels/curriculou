# Copie para .env e preencha. NUNCA suba o .env pro GitHub.

# Porta (a Hostinger normalmente define automaticamente)
PORT=3333

# URL pública do app (o mesmo domínio que serve o site)
FRONTEND_URL=https://seudominio.com
BACKEND_URL=https://seudominio.com

# Mercado Pago — Access Token de PRODUÇÃO (Suas integrações > Credenciais)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Banco MySQL da Hostinger (crie em hPanel > Bancos de Dados MySQL)
# É AQUI que ficam salvas as contas (tabela usuarios), os currículos e os pedidos.
# Sem essas variáveis o app funciona em memória (os dados somem ao reiniciar).
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco
DB_NAME=nome_do_banco

# Segredo para assinar os tokens de login (JWT). Use um valor longo e aleatório.
# Em produção é OBRIGATÓRIO definir — sem ele usa um segredo de desenvolvimento.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
