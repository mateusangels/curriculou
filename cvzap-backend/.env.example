# Copie para .env e preencha. NUNCA suba o .env para o GitHub.

# Access Token de PRODUÇÃO do Mercado Pago (Suas integrações > Credenciais)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL pública do FRONTEND (onde o app está hospedado na Hostinger)
FRONTEND_URL=https://seudominio.com

# URL pública DESTE backend (para o Mercado Pago chamar o webhook)
BACKEND_URL=https://api.seudominio.com

# Porta (a Hostinger costuma definir via variável de ambiente)
PORT=3333
